const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL ?? "/";
---

<footer class="border-t border-ink/10">
  <div class="mx-auto max-w-6xl px-5 py-10">
    <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
      <div>
        <div class="font-display text-lg tracking-tightish">Pratham Shukla</div>
        <div class="mt-1 text-sm text-ink/60">© {year} • All rights reserved.</div>
      </div>

      <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
        <a class="link-underline text-ink/75 hover:text-ink transition" href={`${base}about/`}>About</a>
        <a class="link-underline text-ink/75 hover:text-ink transition" href={`${base}work/`}>Work</a>
        <a class="link-underline text-ink/75 hover:text-ink transition" href={`${base}#contact`}>Contact</a>
      </div>
    </div>
  </div>
</footer>

