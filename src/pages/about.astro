---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL ?? "/";
---

<BaseLayout title="About Pratham Shukla" description="[PLACEHOLDER — about page description for SEO]">
  <section class="mx-auto max-w-6xl px-5 py-16">
    <header class="reveal">
      <p class="text-xs font-semibold tracking-wide text-ink/55">[PLACEHOLDER — section label]</p>
      <h1 class="mt-4 font-display text-5xl leading-[0.95] tracking-tightish sm:text-6xl">About</h1>
    </header>

    <div class="mt-12 grid gap-10 md:grid-cols-12 md:items-start">
      <div class="md:col-span-7 reveal">
        <div class="rounded-3xl border border-ink/10 bg-paper p-7 shadow-soft sm:p-10">
          <!-- [PLACEHOLDER — Long bio] -->
          <h2 class="font-display text-3xl tracking-tightish">[PLACEHOLDER — Who I am]</h2>
          <p class="mt-5 text-base leading-relaxed text-ink/70 sm:text-lg">
            [PLACEHOLDER — A longer personal bio. Who you are, where you come from, what you care about, and what kind of
            work energizes you.]
          </p>
          <p class="mt-5 text-base leading-relaxed text-ink/70 sm:text-lg">
            [PLACEHOLDER — Optional second paragraph. Keep it specific and human.]
          </p>
        </div>
      </div>

      <aside class="md:col-span-5 reveal">
        <div class="space-y-6">
          <div class="rounded-3xl border border-ink/10 bg-white/60 p-7 shadow-soft">
            <h3 class="text-sm font-semibold text-ink">Background / Education</h3>
            <p class="mt-3 text-sm leading-relaxed text-ink/70">
              [PLACEHOLDER — IIT Kanpur, B.Tech + Economics, graduation year]
            </p>
          </div>

          <div class="rounded-3xl border border-ink/10 bg-white/60 p-7 shadow-soft">
            <h3 class="text-sm font-semibold text-ink">What I care about</h3>
            <ul class="mt-4 space-y-3 text-sm text-ink/70">
              <li class="flex gap-3">
                <span class="mt-[0.45rem] h-1.5 w-1.5 flex-none rounded-full bg-accent/70"></span>
                <span>[PLACEHOLDER — value statement]</span>
              </li>
              <li class="flex gap-3">
                <span class="mt-[0.45rem] h-1.5 w-1.5 flex-none rounded-full bg-accent/70"></span>
                <span>[PLACEHOLDER — value statement]</span>
              </li>
              <li class="flex gap-3">
                <span class="mt-[0.45rem] h-1.5 w-1.5 flex-none rounded-full bg-accent/70"></span>
                <span>[PLACEHOLDER — value statement]</span>
              </li>
            </ul>
          </div>

          <div class="rounded-3xl border border-ink/10 bg-white/60 p-7 shadow-soft">
            <h3 class="text-sm font-semibold text-ink">A few personal facts</h3>
            <ul class="mt-4 space-y-2 text-sm text-ink/70">
              <li>[PLACEHOLDER — hobby / interest]</li>
              <li>[PLACEHOLDER — hobby / interest]</li>
              <li>[PLACEHOLDER — quirk / fun detail]</li>
            </ul>
          </div>
        </div>
      </aside>
    </div>

    <div class="mt-14 flex flex-wrap items-center gap-3 reveal">
      <a
        href={`${base}work/`}
        class="inline-flex items-center justify-center rounded-full bg-accent px-6 py-3 text-sm font-semibold text-white shadow-soft hover:translate-y-[-1px] hover:shadow-[0_18px_52px_rgba(11,27,58,0.18)] transition"
      >
        See my work
      </a>
      <a
        href={`${base}#contact`}
        class="inline-flex items-center justify-center rounded-full border border-ink/15 bg-white/70 px-6 py-3 text-sm font-semibold text-ink hover:border-ink/25 hover:bg-white transition"
      >
        Get in touch
      </a>
    </div>
  </section>
</BaseLayout>

