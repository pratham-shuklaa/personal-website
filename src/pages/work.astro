    company: "Scaler (InterviewBit)",
    title: "[PLACEHOLDER — Product Manager]",
    duration: "[PLACEHOLDER — dates]",
    location: "[PLACEHOLDER — location]",
    bullets: [
      "[PLACEHOLDER — What did you build? What changed because of your work?]",
      "[PLACEHOLDER — What did you build? What changed because of your work?]",
      "[PLACEHOLDER — What did you build? What changed because of your work?]"
